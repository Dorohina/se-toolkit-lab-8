{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "coder-model",
      "provider": "custom",
      "maxTokens": 8192,
      "contextWindowTokens": 65536,
      "temperature": 0.1,
      "maxToolIterations": 40,
      "reasoningEffort": null
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": false
  },
  "providers": {
    "custom": {
      "apiKey": "adminvd-secret-qwen-key",
      "apiBase": "http://localhost:42005/v1",
      "extraHeaders": null
    }
  },
  "tools": {
    "mcp_servers": {
      "lms": {
        "type": "stdio",
        "command": "uv",
        "args": ["run", "--with", "lms-mcp", "python", "-m", "mcp_lms"],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "http://localhost:42002",
          "NANOBOT_LMS_API_KEY": "lms-adminvd-key"
        }
      }
    }
  }
}
